# ── Authentication (optional) ─────────────────────────────────────────────────
# Supported: "clerk" — leave empty or remove to disable auth entirely
# VITE_AUTH_PROVIDER=clerk

# Clerk settings (only needed when VITE_AUTH_PROVIDER=clerk)
# VITE_CLERK_PUBLISHABLE_KEY=pk_...
# AUTH_ISSUER_URL=https://your-app.clerk.accounts.dev
#
# Also set in Convex environment (npx convex env set):
#   CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev

# ── Convex ────────────────────────────────────────────────────────────────────
# Convex deployment URL — copied from your Convex dashboard or `npx convex dev` output
VITE_CONVEX_URL=https://<your-deployment>.convex.cloud

# Convex HTTP actions base URL (used for bank OAuth callbacks)
# Same host as above, no trailing slash
VITE_CONVEX_SITE_URL=https://<your-deployment>.convex.site

# LLM provider selection — supported: anthropic (default), openai, google
# LLM_PROVIDER=anthropic

# Model to use — defaults per provider: claude-haiku-4-5 / gpt-4.1-mini / gemini-2.5-flash
# LLM_MODEL=claude-haiku-4-5

# API keys — server-side only, never exposed to the browser (no VITE_ prefix)
# Only the key for your chosen provider is required.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# AES-256-GCM key for encrypting bank OAuth tokens (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this in Convex environment variables (not in .env), for server-side use:
#   npx convex env set TOKEN_ENCRYPTION_KEY <value>
TOKEN_ENCRYPTION_KEY=

# Optional: currency symbol shown in the UI (default: CZK)
# VITE_CURRENCY=EUR
