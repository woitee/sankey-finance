# ── Authentication (optional) ─────────────────────────────────────────────────
# Supported: "clerk" — leave empty or remove to disable auth entirely
# VITE_AUTH_PROVIDER=clerk

# Clerk settings (only needed when VITE_AUTH_PROVIDER=clerk)
# VITE_CLERK_PUBLISHABLE_KEY=pk_...
#
# Also set in Convex environment (npx convex env set):
#   CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev

# ── Convex ────────────────────────────────────────────────────────────────────
# Convex deployment URL — copied from your Convex dashboard or `npx convex dev` output
VITE_CONVEX_URL=https://<your-deployment>.convex.cloud

# Convex HTTP actions base URL (used for bank OAuth callbacks)
# Same host as above, no trailing slash
VITE_CONVEX_SITE_URL=https://<your-deployment>.convex.site

# Optional: currency symbol shown in the UI (default: CZK)
# VITE_CURRENCY=EUR

# ── Convex environment variables ─────────────────────────────────────────────
# Set these via `npx convex env set <NAME> <VALUE>` (NOT in this file):
#
#   LLM_PROVIDER      — anthropic (default), openai, or google
#   LLM_MODEL         — defaults: claude-haiku-4-5 / gpt-4.1-mini / gemini-2.5-flash
#   ANTHROPIC_API_KEY  — required when LLM_PROVIDER=anthropic
#   OPENAI_API_KEY     — required when LLM_PROVIDER=openai
#   GOOGLE_API_KEY     — required when LLM_PROVIDER=google
#   TOKEN_ENCRYPTION_KEY — AES-256-GCM key for bank OAuth tokens (64 hex chars)
#     Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
